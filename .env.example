OPEN_MESSENGER_ENVIRONMENT=dev
OPEN_MESSENGER_CONTENT_BACKEND=memory
OPEN_MESSENGER_METADATA_BACKEND=memory
OPEN_MESSENGER_FILE_STORAGE_BACKEND=local
OPEN_MESSENGER_STORAGE_DIR=data/storage
OPEN_MESSENGER_REDIS_URL=redis://localhost:6379/0
OPEN_MESSENGER_REDIS_CONTENT_KEY_PREFIX=open_messenger:content
OPEN_MESSENGER_MYSQL_DSN=mysql+pymysql://app:app@localhost:3306/open_messenger
OPEN_MESSENGER_MYSQL_TABLE_PREFIX=open_messenger
OPEN_MESSENGER_FILES_ROOT_DIR=data/files
OPEN_MESSENGER_MAX_UPLOAD_MB=50
OPEN_MESSENGER_ADMIN_API_TOKEN=dev-admin-token
OPEN_MESSENGER_TOKEN_SIGNING_SECRET=dev-signing-secret
OPEN_MESSENGER_RATE_LIMIT_MAX_REQUESTS=60
OPEN_MESSENGER_RATE_LIMIT_WINDOW_SECONDS=60
OPEN_MESSENGER_TRACING_ENABLED=false
OPEN_MESSENGER_TRACING_SERVICE_NAME=open-messenger-api
OPEN_MESSENGER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
